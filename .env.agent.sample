# agent 用 env サンプル。`cp .env.agent.sample agent.env` して値を入れる。
# Makefile の ENV_FILE（既定 agent.env）が docker --env-file で読み込む。

# Claude（LLM）接続に必須
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 任意: 独自エンドポイント/プロキシを使う場合のみ
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 任意: weather ツールを実 MCP server に差し替えたら使う（今はモックなので不要）
# WEATHER_API_KEY=