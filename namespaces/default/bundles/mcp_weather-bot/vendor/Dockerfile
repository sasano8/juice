# generated by juice — `juice bundle bundle` で再生成（手編集しない）
FROM python:3.12-slim
WORKDIR /app
# 依存だけ先に入れてレイヤをキャッシュ（requirements.txt 不変なら再インストールしない）
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt
# その後に成果物本体をコピー（ソース変更はこのレイヤ以降だけを無効化）
COPY . /app
EXPOSE 8000
# mode は docker run の引数で渡す（api / ui / mcp_server）。既定は api。
ENTRYPOINT ["python", "entrypoint.py"]
CMD ["api"]
